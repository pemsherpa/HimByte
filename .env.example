# ─────────────────────────────────────────────────────────
#  Himbyte — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

# Your project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL= 

# Anon/public key — safe to expose to frontend
SUPABASE_ANON_KEY=

# Service Role key — KEEP SECRET. Required for:
#   • Restaurant self-signup (POST /api/onboarding/register-owner)
#   • Reliable server-side writes that bypass RLS when needed
SUPABASE_SERVICE_ROLE_KEY=

# Database password (Settings → Database). For `npm run migrate` either:
# • Paste Session pooler URI as DATABASE_URL (Supabase → Connect → Session mode — works on IPv4), or
# • Set SUPABASE_DB_PASSWORD + SUPABASE_DB_REGION (e.g. ap-south-1 from Project Settings → General → Region)
# DATABASE_URL=postgres://postgres.xxxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_REGION=

# ── Frontend (Vite) ───────────────────────────────────────
# These are injected into the browser bundle (VITE_ prefix required)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Production: Render API origin (no trailing slash). Omit for local dev (Vite proxies /api → localhost:3001).
# VITE_API_URL=https://himbyte-api.onrender.com

# Production (Cloudflare Pages): full URL for QR codes (no trailing slash), e.g. https://himbyte.pages.dev
# Never set this to the text "window.location.origin" — env values are literal strings and will break QR links.
# If unset or invalid, the app uses the real window.location.origin at runtime.
# VITE_APP_URL=https://himbyte.pages.dev

# ── Backend ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Comma-separated browser origins allowed when NODE_ENV=production (CORS).
# Example: https://app.himbyte.com,https://himbyte.vercel.app
CLIENT_URL=http://localhost:5173

# The URL where your frontend runs (used for QR code generation)
# Change to your production domain when deploying
APP_URL=http://localhost:5173

# Public URL of this API (no /api path). Required for eSewa if the API host is not obvious from request headers.
# Example: https://himbyte.onrender.com (SPA can live on a different domain, e.g. Cloudflare Pages)
# API_PUBLIC_URL=

# ── eSewa ePay v2 (pay at counter — Table Bills) ────────────
# Official docs: https://developer.esewa.com.np/pages/Epay-V2
# Test credentials: https://developer.esewa.com.np/pages/Test-credentials
#
# UAT / testing (default): POST form to rc-epay host; use EPAYTEST merchant code & test secret below.
# Production: set ESEWA_FORM_URL to https://epay.esewa.com.np/api/epay/main/v2/form and credentials from eSewa.
#
# Troubleshooting (browser shows POST …/api/epay/login?bookingId=… → 401 or "Service is currently unavailable"):
# • That response is from eSewa’s gateway, not Himbyte — usually UAT outage, IP blocking, or merchant/product
#   code not enabled for the gateway you are hitting. Confirm TEST credentials on developer.esewa.com.np,
#   try another network/VPN, and contact eSewa support if rc-epay repeatedly returns 401.
# • Ensure APP_URL / CLIENT_URL match the domain you registered with eSewa for success/failure redirects.
#
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_FORM_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
# Optional: transaction status API (see Epay-V2 “Status Check”) — UAT vs prod host if you poll manually
# ESEWA_STATUS_BASE_URL=https://uat.esewa.com.np

# ── Email (SMTP) ──────────────────────────────────────────
# Used for transactional guest mail: order placed and order ready (when SMTP is configured).
# For Gmail: create an App Password and use smtp.gmail.com:465 (secure) or 587 (STARTTLS).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Himbyte <no-reply@himbyte.com>"

# Comma-separated inboxes for /api/demo-request (Try menu lead form). Defaults to Pema & Kashchit if unset.
# DEMO_REQUEST_TO=ptssherpa5@gmail.com,thapakashchitbikram@gmail.com

# ─────────────────────────────────────────────────────────
#  SETUP STEPS:
#  1. Copy this file to himbyte/.env (repo ROOT — not client/.env)
#  2. Supabase Dashboard → Settings → API → paste URL, anon, service_role
#  3. Vite is configured (envDir) to read this same root .env for VITE_* vars
#  4. Apply SQL in supabase/migrations/ to your project (SQL editor or CLI)
#  5. cd server && node src/index.js   and   cd client && npx vite
#  6. Verify: http://localhost:3001/api/health → demo: false, supabase.configured: true
#  See working.md for full flow + demo login emails/passwords.
# ─────────────────────────────────────────────────────────
