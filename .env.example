# ─────────────────────────────────────────────────────────
#  Himbyte — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

# Your project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Anon/public key — safe to expose to frontend
SUPABASE_ANON_KEY=

# Service Role key — KEEP SECRET, only used by the backend seed script
SUPABASE_SERVICE_ROLE_KEY=

# ── Frontend (Vite) ───────────────────────────────────────
# These are injected into the browser bundle (VITE_ prefix required)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Backend ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# The URL where your frontend runs (used for QR code generation)
# Change to your production domain when deploying
APP_URL=http://localhost:5174

# ─────────────────────────────────────────────────────────
#  SETUP STEPS:
#  1. Go to https://supabase.com → New Project
#  2. Run supabase/migrations/001_initial_schema.sql in the SQL editor
#  3. Copy the URL and keys above
#  4. Run: node seed.js   ← seeds both restaurants with full menus
#  5. Run: npm run dev    ← starts the app
# ─────────────────────────────────────────────────────────
